# VS Code (user-specific)
.vscode/

# macOS system files
.DS_Store
**/.DS_Store

# Tests are tracked — they're template maintenance files, not project files

# Python cache
__pycache__/
**/__pycache__/
*.pyc

# Local settings
.claude/settings.local.json

# Per-file sync state sidecar (project state, not template content)
.claude/.sync-state.json

# Prevent nested .claude directories
.claude/.claude/
